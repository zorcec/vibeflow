{
  "name": "@vibeflow-tools/cli",
  "version": "0.8.0",
  "description": "Vibeflow CLI for frontend prototyping with LLM assistance — review, annotate, and iterate on HTML prototypes",
  "license": "Apache-2.0",
  "author": "Tomislav Zorcec <vibeflow.tools@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/cli/",
    "dist/client/",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/overlay.css",
    "dist/overlay-host.css",
    "dist/chunk-*.js",
    "dist/files-*.js",
    "dist/workspace-*.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "vibeflow": "dist/cli/index.js",
    "vf": "dist/cli/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/gen-overlay-css.mjs && mkdir -p dist/client && node scripts/gen-overlay-bundle.mjs && node scripts/gen-kanban-css.mjs",
    "build": "tsup && tsup --config tsup.cli.config.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:browser": "vitest run --config vitest.pw.config.ts",
    "mutation": "node scripts/mutation.mjs",
    "mutation:ci": "node scripts/mutation.mjs --all",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "serve:designs": "node dist/cli/index.js serve ../../docs/ --port 3701"
  },
  "keywords": [
    "vibeflow",
    "prototype",
    "annotation",
    "ai-agent",
    "llm",
    "html",
    "cli",
    "copilot",
    "claude",
    "kanban",
    "task-management",
    "overlay",
    "browser",
    "feedback",
    "vibe-coding",
    "frontend"
  ],
  "dependencies": {
    "@inquirer/select": "^5.1.3",
    "@trpc/server": "^11.14.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "html2canvas": "^1.4.1",
    "open": "^10.1.0",
    "posthog-node": "^5.30.4",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.0",
    "@vibeflow-tools/shared": "workspace:*",
    "@vibeflow-tools/ui": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
