{
  "name": "@vibeflow-tools/ui-prototyping",
  "version": "0.1.0",
  "description": "In-app variant switching for React — page-level and component-level prototyping with URL persistence",
  "license": "Apache-2.0",
  "author": "Tomislav Zorcec <vibeflow.tools@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "demo.html"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "mutation": "node scripts/mutation.mjs",
    "mutation:ci": "node scripts/mutation.mjs --all",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vibeflow",
    "prototyping",
    "variant",
    "switcher",
    "react",
    "url-params",
    "design-variants",
    "a-b-testing",
    "component-variants",
    "dev-tools"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^29.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
